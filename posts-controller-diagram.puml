@startuml Posts Controller Diagram

class PostsController {
  +constructor(postsService: PostsService)
  +create(createPostDto: CreatePostDto, req: any): any
  +findAll(searchPostDto: SearchPostDto): any
  +findMine(req: any): any
  +findOne(id: number): any
  +update(id: number, updatePostDto: UpdatePostDto, req: any): any
  +delete(id: number, req: any): any
}

class PostsService {
  // Methods for post CRUD
}

class PostEntity {
  +id: number
  +title: string
  +description: string
  +price: number
  +area: number
  +address: string
  +latitude: number
  +longitude: number
  +rejectionReason: string
  +resubmittedAt: Date
  +max_occupancy: number
  +status: PostStatus
  +createdAt: Date
  +updatedAt: Date
  +userId: number
  +categoryId: number
  +user: UserEntity
  +category: CategoryEntity
  +images: PostImageEntity[]
  +amenities: AmenityEntity[]
  +reviews: ReviewEntity[]
}

class UserEntity {
  +id: number
  +email: string
  +username: string
  +password_hash: string
  +roleId: number
  +is_active: boolean
  +createdAt: Date
  +updatedAt: Date
  +role: RoleEntity
  +profile: UserProfileEntity
  +posts: PostEntity[]
}

class CategoryEntity {
  +id: number
  +name: string
  +description: string
  +posts: PostEntity[]
}

class AmenityEntity {
  +id: number
  +name: string
  +icon_url: string
  +posts: PostEntity[]
}

class PostImageEntity {
  +id: number
  +postId: number
  +image_url: string
  +is_video: boolean
  +post: PostEntity
}

class ReviewEntity {
  +id: number
  +rating: number
  +comment: string
  +createdAt: Date
  +userId: number
  +postId: number
  +user: UserEntity
  +post: PostEntity
}

' Relationships
PostsController --> PostsService : uses
PostsService --> PostEntity : manages
PostsService --> UserEntity : manages
PostsService --> CategoryEntity : manages
PostsService --> AmenityEntity : manages
PostsService --> PostImageEntity : manages
PostsService --> ReviewEntity : manages

@enduml
